COMPOSE_PROJECT_NAME=hnaj

# Published ports on the host machine.
FRONTEND_PORT=8082
BACKEND_PORT=8081
MYSQL_PORT=3307

# Laravel runtime configuration. APP_KEY is generated in hnaj-be/.env by Laravel.
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8081

# MySQL configuration. DB_HOST is the Docker service name inside Compose.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hnaj
DB_USERNAME=hnaj
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root
